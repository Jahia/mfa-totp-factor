{
  "name": "mfa-factors-login-ui",
  "description": "Shared sign-in UI for the MFA factors — a Jahia authentication template that performs username/password then TOTP / WebAuthn / email-code verification.",
  "version": "1.0.0-SNAPSHOT",
  "type": "module",
  "files": [
    "dist",
    "src/**/*.cnd",
    "settings",
    "static"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build && yarn package",
    "clean": "rm -rf dist/",
    "dev": "vite build --watch",
    "package": "yarn pack --filename dist/package.tgz",
    "watch": "yarn dev"
  },
  "dependencies": {
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "clsx": "^2.1.1",
    "modern-normalize": "^3.0.1"
  },
  "devDependencies": {
    "@jahia/javascript-modules-library": "^0.9.2",
    "@jahia/vite-plugin": "^0.9.2",
    "@types/react": "^19.1.2",
    "i18next": "^25.6.0",
    "react": "^19.1.0",
    "react-i18next": "^15.7.4",
    "typescript": "^5.8.3",
    "typescript-plugin-css-modules": "^5.1.0",
    "vite": "^7.0.0"
  },
  "jahia": {
    "name": "MFA factors Login UI",
    "maven": {
      "groupId": "org.jahia.community"
    },
    "module-dependencies": "default,user-password-authentication-api,mfa-factors-totp",
    "module-type": "module",
    "required-version": "8.2.3.0",
    "server": "dist/server/index.js",
    "static-resources": "/dist/client,/dist/assets,/locales,/images,/icons"
  }
}
